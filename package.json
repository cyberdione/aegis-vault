{
  "name": "@cyberdione/aegis-vault-web",
  "version": "0.3.1",
  "description": "Encrypted browser identity vault — passphrase + WebAuthn-PRF, AES-256-GCM at rest, HSM-shaped per-purpose Ed25519 signing slots. Vanilla core + Web Component widget + optional framework adapters.",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/cyberdione/aegis-vault.git"
  },
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./types": {
      "types": "./dist/types.d.ts",
      "import": "./dist/types.js"
    },
    "./widget": {
      "types": "./dist/widget/index.d.ts",
      "import": "./dist/widget/index.js"
    },
    "./webauthn": {
      "types": "./dist/webauthn.d.ts",
      "import": "./dist/webauthn.js"
    },
    "./react": {
      "types": "./dist/react/index.d.ts",
      "import": "./dist/react/index.js"
    },
    "./pkg/*": "./pkg/*"
  },
  "files": [
    "dist",
    "pkg",
    "src",
    "scripts/build-wasm.sh",
    "README.md",
    "THREATMODEL.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build:wasm": "bash scripts/build-wasm.sh",
    "build:ts": "tsc -p tsconfig.json",
    "build": "npm run build:wasm && npm run build:ts",
    "prepare": "npm run build",
    "clean": "rm -rf dist pkg"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  },
  "devDependencies": {
    "typescript": "^5.4.0",
    "@types/react": "^18.2.0",
    "react": "^18.2.0"
  },
  "keywords": [
    "vault",
    "argon2",
    "ed25519",
    "webauthn",
    "browser",
    "indexeddb",
    "hsm"
  ],
  "publishConfig": {
    "access": "public"
  }
}
